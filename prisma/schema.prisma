// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  id        Int      @id @default(autoincrement())
  field     String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LicenseType {
  SINGLE
  VOLUME
}

enum LicenseStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  INACTIVE
}

enum AssignmentStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

model Product {
  id          String       @id
  productName String
  description String?
  vendor      String?
  createdById Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   User         @relation(fields: [createdById], references: [id])
  licenseKeys LicenseKey[]

  @@index([createdById])
  @@map("products")
}

model LicenseKey {
  id                    String              @id
  productId             String
  licenseName           String
  licenseKey            String
  licenseType           LicenseType         @default(SINGLE)
  maxUsages             Int                 @default(1)
  currentUsages         Int                 @default(0)
  requiresAdminApproval Boolean             @default(true)
  status                LicenseStatus       @default(ACTIVE)
  expiresAt             DateTime?
  uploadedById          Int
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  product               Product             @relation(fields: [productId], references: [id])
  uploadedBy            User                @relation(fields: [uploadedById], references: [id])
  assignments           LicenseAssignment[]

  @@index([productId])
  @@index([uploadedById])
  @@map("license_keys")
}

model LicenseAssignment {
  id             String           @id
  licenseKeyId   String
  userId         Int
  status         AssignmentStatus @default(PENDING)
  requestedAt    DateTime         @default(now())
  processedAt    DateTime?
  processedById  Int?
  assignmentNote String?
  licenseKey     LicenseKey       @relation(fields: [licenseKeyId], references: [id])
  processedBy    User?            @relation("LicenseAssignmentProcessedBy", fields: [processedById], references: [id])
  user           User             @relation("LicenseAssignmentUser", fields: [userId], references: [id])

  @@index([licenseKeyId])
  @@index([userId])
  @@index([processedById])
  @@map("license_assignments")
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  name        String?
  password    String
  permissions Permission[] @default([])

  createdBy   User?    @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdUsers                User[]              @relation("UserCreatedBy")
  processedLicenseAssignments LicenseAssignment[] @relation("LicenseAssignmentProcessedBy")
  licenseAssignments          LicenseAssignment[] @relation("LicenseAssignmentUser")
  licenseKeys                 LicenseKey[]
  products                    Product[]

  @@index([createdById])
  @@index([email])
}

enum Permission {
  ADMIN
}
