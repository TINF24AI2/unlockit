// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  id        Int      @id @default(autoincrement())
  field     String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LicenseType {
  SINGLE
  VOLUME
}

enum LicenseStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  INACTIVE
}

enum AssignmentStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

model Product {
  id          String       @id
  productName String
  description String?
  vendor      String?
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  licenseKeys LicenseKey[]

  @@index([createdById])
  @@map("products")
}

model LicenseKey {
  id                    String              @id
  productId             String
  licenseName           String
  licenseKey            String
  licenseType           LicenseType         @default(SINGLE)
  maxUsages             Int                 @default(1)
  currentUsages         Int                 @default(0)
  requiresAdminApproval Boolean             @default(true)
  status                LicenseStatus       @default(ACTIVE)
  expiresAt             DateTime?
  uploadedById          String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  product               Product             @relation(fields: [productId], references: [id])
  assignments           LicenseAssignment[]

  @@index([productId])
  @@index([uploadedById])
  @@map("license_keys")
}

model LicenseAssignment {
  id             String           @id
  licenseKeyId   String
  userId         String
  status         AssignmentStatus @default(PENDING)
  requestedAt    DateTime         @default(now())
  processedAt    DateTime?
  processedById  String?
  assignmentNote String?
  licenseKey     LicenseKey       @relation(fields: [licenseKeyId], references: [id])

  @@index([licenseKeyId])
  @@index([userId])
  @@index([processedById])
  @@map("license_assignments")
}
